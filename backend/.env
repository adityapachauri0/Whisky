# Environment
NODE_ENV=development

# Server
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/whiskey-investment

# JWT Configuration
JWT_SECRET=development-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@viticult.co.uk
EMAIL_FROM_NAME=ViticultWhisky
ADMIN_EMAIL=admin@viticult.co.uk

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ENCRYPTION_KEY=development-encryption-key-32chars
COOKIE_SECRET=development-cookie-secret

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=false

# Optional Services (uncomment and configure as needed)
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
# REDIS_URL=
# CALENDLY_API_KEY=